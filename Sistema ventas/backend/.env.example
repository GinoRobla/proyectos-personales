# Variables de entorno - Backend
# Copia este archivo como .env y ajusta los valores

# Puerto del servidor (Railway asigna automáticamente en producción)
PORT=3001

# Host del servidor (Railway asigna automáticamente en producción) 
HOST=127.0.0.1

# URL de base de datos PostgreSQL (Railway la proporciona automáticamente)
# En desarrollo local, deja este campo vacío para usar SQLite
DATABASE_URL=

# Entorno de ejecución
NODE_ENV=development

# CORS - Dominio del frontend (necesario para producción)
# Ejemplo: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:5173